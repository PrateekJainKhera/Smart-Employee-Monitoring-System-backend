# =============================================
# Smart Employee Monitoring System — Config
# Copy this file to .env and fill in values
# =============================================

# Camera RTSP streams (comma-separated)
# For testing with webcam use: 0
CAMERA_URLS=rtsp://192.168.1.1/stream1,rtsp://192.168.1.2/stream1

# YOLO model weights path (relative to backend/)
YOLO_WEIGHTS_PATH=weights/yolov8n.pt

# Face recognition confidence thresholds
FACE_RECOGNITION_THRESHOLD=0.6
FACE_HIGH_THRESHOLD=0.65
FACE_MEDIUM_THRESHOLD=0.5

# Break duration rules (minutes)
BREAK_SHORT_MIN=10
BREAK_MEDIUM_MIN=20

# Path to save face embeddings (pkl file)
EMBEDDINGS_PATH=data/embeddings.pkl

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# App server
HOST=0.0.0.0
PORT=8000

# ---- Phase 5+: MS SQL Server connection (pyodbc connection string) ----
# Uncomment and fill in your SQL Server details to enable attendance tracking.
# Format: DRIVER={ODBC Driver 17 for SQL Server};SERVER=<host>;DATABASE=<db>;UID=<user>;PWD=<password>;
#
# Examples:
#   Local SQL Server with Windows Auth:
#     DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=EmployeeMonitor;Trusted_Connection=yes;
#
#   Local SQL Server with SQL Auth:
#     DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=EmployeeMonitor;UID=sa;PWD=YourPassword123;
#
#   Named instance:
#     DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost\SQLEXPRESS;DATABASE=EmployeeMonitor;UID=sa;PWD=YourPassword123;
#
# DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=EmployeeMonitor;UID=sa;PWD=YourPassword123;
