# =============================================
# Smart Employee Monitoring System — Config
# Copy this file to .env and fill in values
# =============================================

# Camera RTSP streams (comma-separated)
# For testing with webcam use: 0
CAMERA_URLS=rtsp://192.168.1.1/stream1,rtsp://192.168.1.2/stream1

# YOLO model weights path (relative to backend/)
YOLO_WEIGHTS_PATH=weights/yolov8n.pt

# Face recognition confidence thresholds
FACE_RECOGNITION_THRESHOLD=0.6
FACE_HIGH_THRESHOLD=0.65
FACE_MEDIUM_THRESHOLD=0.5

# Break duration rules (minutes)
BREAK_SHORT_MIN=10
BREAK_MEDIUM_MIN=20

# Path to save face embeddings (pkl file)
EMBEDDINGS_PATH=data/embeddings.pkl

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# App server
HOST=0.0.0.0
PORT=8000

# ---- Phase 5+ only (leave commented until Phase 5) ----
# DATABASE_URL=mssql+pyodbc://user:password@server/dbname?driver=ODBC+Driver+17+for+SQL+Server
